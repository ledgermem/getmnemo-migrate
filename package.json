{
  "name": "@getmnemo/migrate",
  "version": "0.1.0",
  "description": "Importer CLI for migrating memories from Mem0, Zep, Supermemory, Letta, or raw JSONL into Mnemo.",
  "type": "module",
  "bin": {
    "getmnemo-migrate": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@getmnemo/memory": "^0.1.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "ora": "^8.1.1",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "getmnemo",
    "migrate",
    "import",
    "mem0",
    "zep",
    "supermemory",
    "letta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getmnemo/getmnemo-migrate.git"
  },
  "homepage": "https://github.com/getmnemo/getmnemo-migrate#readme",
  "bugs": {
    "url": "https://github.com/getmnemo/getmnemo-migrate/issues"
  }
}
